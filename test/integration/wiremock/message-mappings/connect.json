{
  "name": "WiNet connect",
  "trigger": {
    "type": "message",
    "channel": {
      "type": "websocket",
      "initiatingRequestPattern": {
        "urlPath": "/ws/home/overview"
      }
    },
    "message": {
      "body": {
        "matchesJsonPath": {
          "expression": "$.service",
          "equalTo": "connect"
        }
      }
    }
  },
  "actions": [
    {
      "type": "send",
      "channelTarget": {
        "type": "originating"
      },
      "message": {
        "body": {
          "data": "{\"result_code\":1,\"result_msg\":\"success\",\"result_data\":{\"service\":\"connect\",\"token\":\"mock_token\",\"uid\":1,\"ip\":\"192.168.1.100\",\"forceModifyPasswd\":0}}"
        }
      }
    }
  ]
}
